{
  "extends": "./tsconfig.json",
  "include": [
    "server/**/*",
    "shared/**/*",
    "script/**/*"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "**/*.test.ts",
    "vite.config.ts",
    "vite-plugin-meta-images.ts",
    "server/vite.ts"
  ],
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "paths": {
      "@shared/*": ["./shared/*"]
    }
  }
}
